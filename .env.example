# PNF-AIMS Provider API Keys
# Copy this file to .env and add your actual API keys
# NEVER commit .env to version control

# Suno AI - Music Generation
SUNO_API_KEY=your_suno_api_key_here

# Mureka - Music Generation
MUREKA_API_KEY=your_mureka_api_key_here

# ElevenLabs - Voice Synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_default_voice_id_here

# (Optional) Provider Selection and Fallback
# PREFERRED_PROVIDER=suno
# FALLBACK_PROVIDERS=mureka,elevenlabs

# (Optional) Request Timeout (milliseconds)
# PROVIDER_REQUEST_TIMEOUT=30000

# (Optional) Enable Provider Logging
# PROVIDER_DEBUG=false

# UdioProAPI third-party integration (shared for Suno + Udio)
# If set, backend uses this provider for Suno and optionally Udio.
# UDIOPROAPI_API_KEY=your_udioproapi_key_here
# UDIOPROAPI_BASE_URL=https://udioapi.pro/api
# UDIOPROAPI_SUNO_GENERATE_PATH=/v2/generate
# UDIOPROAPI_UDIO_GENERATE_PATH=/v2/generate
# UDIOPROAPI_STATUS_PATH=/v1/jobs/{jobId}
# MiniMax (integrated provider) endpoint:
# /v2/minimax/generate

# Mureka direct API integration
# MUREKA_API_KEY=your_mureka_key_here
# MUREKA_BASE_URL=https://api.mureka.ai
# MUREKA_GENERATE_PATH=/v1/generate
# MUREKA_STATUS_PATH=/v1/jobs/{jobId}

# Udio direct API integration
# UDIO_API_KEY=your_udio_key_here
# UDIO_BASE_URL=https://api.udio.com
# UDIO_GENERATE_PATH=/v1/generate
# UDIO_STATUS_PATH=/v1/jobs/{jobId}

# Optional MySQL persistence for request/job tracking
# If omitted, backend uses in-memory storage.
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=eFlatminor1@
# MYSQL_DATABASE=pnf_aims
# MYSQL_TABLE=pnf_request_jobs
# MYSQL_CONNECTION_LIMIT=10
# MYSQL_SSL=false
# MYSQL_SSL_REJECT_UNAUTHORIZED=true
# MYSQL_SSL_CA_BASE64=
